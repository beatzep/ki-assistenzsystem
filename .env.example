OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ENABLED=true

# Supabase (Auth + learner_profiles)
# Lokal: URL und anon key aus `supabase status` (bei angepassten Ports z. B. http://127.0.0.1:55421)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: für E-Mail-Redirect und OAuth (lokal z. B. http://localhost:3000)
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
